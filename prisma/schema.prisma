// prisma/schema.prisma
// RobloxGamingTracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//// Auth models (optional but recommended with Auth.js / NextAuth) ////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//// Core LoL tracking models ////

/// Tracked player: one row per Riot account (puuid)
model TrackedPlayer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Riot identifiers
  puuid      String  @unique // primary cross-region identifier
  accountId  String?         // legacy id
  summonerId String?         // summoner-v4 id

  // Riot ID identity
  gameName String
  tagLine  String

  // Platform routing
  region        String // e.g. "euw1", "na1" (platform)
  routingRegion String // e.g. "europe", "americas" (regional routing for account-v1/match-v5)

  rankSnapshots     RankSnapshot[]
  rankEvents        RankEvent[]
  matchParticipants MatchParticipant[]
  syncLease         PlayerSyncLease?

  @@index([region])
  @@index([routingRegion])
  @@index([gameName, tagLine, region])
}

/// Single row: which tracked player to sync next on `/api/cron/sync?mode=step` (short cron timeouts).
model CronSyncState {
  id           String   @id // always "singleton"
  lastPlayerId String?
  updatedAt    DateTime @updatedAt
}

/// One active lease per player during sync to avoid cron/manual overlap.
model PlayerSyncLease {
  playerId String @id
  player   TrackedPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  owner     String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

/// Rank snapshot: time-series of rank info per queue
model RankSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trackedPlayerId String
  trackedPlayer   TrackedPlayer @relation(fields: [trackedPlayerId], references: [id], onDelete: Cascade)

  queueType    String // e.g. "RANKED_SOLO_5x5", "RANKED_FLEX_SR"
  tier         String // IRON, BRONZE, SILVER, GOLD, PLATINUM, EMERALD, DIAMOND, MASTER, GRANDMASTER, CHALLENGER
  rank         String // I, II, III, IV (empty for MASTER+)
  leaguePoints Int    @default(0)
  wins         Int    @default(0)
  losses       Int    @default(0)

  @@index([trackedPlayerId, createdAt])
  @@index([trackedPlayerId, queueType, createdAt])
}

/// Rank event: milestone from snapshot changes (placement, promo, demotion, new peak). Used for UI and future notifications.
model RankEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  trackedPlayerId String
  trackedPlayer   TrackedPlayer @relation(fields: [trackedPlayerId], references: [id], onDelete: Cascade)

  eventType String // PLACED | PROMOTED | DEMOTED | NEW_PEAK | REACHED_100_LP
  queueType String // e.g. RANKED_SOLO_5x5

  // Before state (null for PLACED)
  tierBefore       String?
  rankBefore       String?
  leaguePointsBefore Int?

  // After state (always set)
  tierAfter       String
  rankAfter       String
  leaguePointsAfter Int

  // Snapshot that triggered this event (optional link; multiple events can reference same snapshot)
  rankSnapshotId String?

  @@index([trackedPlayerId, createdAt])
  @@index([trackedPlayerId, queueType, createdAt])
}

/// Match: one row per Riot matchId globally
model Match {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  riotMatchId  String   @unique // prevents duplicate matches
  gameStartAt  DateTime       // from match-v5 `info.gameStartTimestamp`
  queueId      Int      @default(0) // Riot queue id (420 solo, 440 flex, etc.)
  gameDuration Int      @default(0) // seconds

  participants MatchParticipant[]

  @@index([gameStartAt])
  @@index([queueId])
}

/// MatchParticipant: one row per tracked player per match
model MatchParticipant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  matchId         String
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  trackedPlayerId String
  trackedPlayer   TrackedPlayer @relation(fields: [trackedPlayerId], references: [id], onDelete: Cascade)

  // Gameplay stats
  championId   Int      @default(0)
  championName String?
  kills        Int      @default(0)
  deaths       Int      @default(0)
  assists      Int      @default(0)
  win          Boolean  @default(false)
  teamPosition String?  // TOP, JUNGLE, MIDDLE, BOTTOM, UTILITY
  lane         String?  // individualPosition, if you want both

  cs          Int @default(0)      // total minions + jungle
  gold        Int @default(0)
  damageDealt Int @default(0)      // to champions
  visionScore Int @default(0)

  // Prevent duplicate participant rows for same player+match
  @@unique([matchId, trackedPlayerId])

  // Useful for per-player timelines and aggregates
  @@index([trackedPlayerId, createdAt])
  @@index([trackedPlayerId, win])
}